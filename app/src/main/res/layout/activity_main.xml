<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GX RADAR"
        android:textSize="38sp"
        android:textStyle="bold"
        android:textColor="@color/radar_blue"
        android:letterSpacing="0.3"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="60dp" />

    <TextView
        android:id="@+id/tvSub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Albion Online · East Server · Debug Build"
        android:textSize="12sp"
        android:textColor="@color/text_dim"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="6dp" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="&#9675; STOPPED"
        android:textSize="13sp"
        android:textColor="@color/status_off"
        android:gravity="center"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="36dp"
        app:layout_constraintTop_toBottomOf="@id/tvSub"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnOverlayPerm"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="Grant Overlay Permission"
        app:backgroundTint="@color/radar_orange"
        android:textColor="@color/bg_dark"
        android:layout_marginHorizontal="48dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnToggle"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Start Radar"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/radar_blue"
        android:layout_marginHorizontal="48dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnOverlayPerm"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnShareLog"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:text="Share Debug Log"
        android:textSize="13sp"
        app:backgroundTint="#1e1e2e"
        app:strokeColor="#444455"
        app:strokeWidth="1dp"
        android:textColor="#8888aa"
        android:layout_marginHorizontal="48dp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/btnToggle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvDebugHint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Start radar &#8594; enter zone &#8594; wait 15s &#8594; tap Share Log"
        android:textSize="10sp"
        android:textColor="@color/text_dim"
        android:gravity="center"
        android:layout_marginHorizontal="48dp"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/btnShareLog"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0.0 &#8212; Step 2 Debug"
        android:textSize="11sp"
        android:textColor="@color/text_dim"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="24dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
